
#include <iostream>
using namespace std;
int indx=0;
    int arr1[100];
    void reverse(int arr[],int n){
    if(n<0){
        return;
    }
    arr1[indx]=arr[n];
    n--;
    indx++;
    
    reverse(arr,n);
}
int main() {
    int n=4;
    int arr[]={1,2,3,4,5};
    reverse(arr,4);
    for( int i=0;i<=n;i++){
        cout<<arr1[i]<<" ";
    }
    return 0;
}
